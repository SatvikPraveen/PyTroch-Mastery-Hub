# EditorConfig — https://editorconfig.org

# Top-most .editorconfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# Jupyter Notebooks (JSON format)
[*.ipynb]
indent_style = space
indent_size = 1
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# TOML files
[*.toml]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Makefiles (must use tabs)
[Makefile]
indent_style = tab
indent_size = 4

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Documentation RST files
[*.rst]
indent_style = space
indent_size = 3

# Configuration files
[*.cfg]
indent_style = space
indent_size = 4

[*.ini]
indent_style = space
indent_size = 4

# Requirements files
[requirements*.txt]
trim_trailing_whitespace = true
insert_final_newline = true
